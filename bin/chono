#!/usr/bin/env -S node --max-old-space-size=8192

/**
 * Chono — multi-model agentic CLI
 *
 * Usage:
 *   chono --think <path>  # DeepSeek R1 (deepseek-reasoner)
 *   chono --pro <path>    # DeepSeek V4 Pro (deepseek-v4-pro)
 *   chono --flash <path>  # DeepSeek V4 Flash (deepseek-v4-flash)
 */

import { existsSync, readFileSync, writeFileSync } from 'fs'
import { join, dirname, resolve } from 'path'
import { fileURLToPath, pathToFileURL } from 'url'
import { spawn, execSync, spawnSync } from 'child_process'

const FLAGS = {
  '--think': 'deepseek-reasoner',
  '--pro':   'deepseek-v4-pro',
  '--flash': 'deepseek-v4-flash',
}

const __dirname = dirname(fileURLToPath(import.meta.url))
const LITELLM_URL  = process.env.LITELLM_BASE_URL ?? 'http://127.0.0.1:4000'
const LITELLM_PORT = '4000'
const LITELLM_CFG  = join(process.env.HOME ?? '/tmp', '.chono', 'litellm.yaml')

function isLitellmUp() {
  try { execSync(`curl -sf http://127.0.0.1:${LITELLM_PORT}/health`, { stdio: 'ignore' }); return true } catch { return false }
}

function startLitellm() {
  if (isLitellmUp()) return Promise.resolve()
  const litellmBin = execSync('which litellm', { encoding: 'utf8' }).trim()
  const child = spawn(litellmBin, ['--config', LITELLM_CFG, '--port', LITELLM_PORT], {
    env:      { ...process.env, LITELLM_LOCAL_MODEL_COST_MAP: 'true' },
    stdio:    'ignore',
    detached: true,
  })
  child.unref()
  return new Promise((resolve, reject) => {
    const deadline = Date.now() + 10000
    const poll = () => {
      if (isLitellmUp()) return resolve()
      if (Date.now() > deadline) return reject(new Error('LiteLLM did not start within 10s'))
      setTimeout(poll, 300)
    }
    setTimeout(poll, 500)
  })
}

function ensureSshKeepalive() {
  const SSHD_CONFIG = '/etc/ssh/sshd_config'
  try {
    let config = readFileSync(SSHD_CONFIG, 'utf8')
    if (/^\s*ClientAliveInterval\s+[1-9]/m.test(config)) return

    if (/ClientAliveInterval/i.test(config)) {
      config = config.replace(/^#?\s*ClientAliveInterval\s+.*/m, 'ClientAliveInterval 60')
    } else {
      config += '\nClientAliveInterval 60\n'
    }
    if (/ClientAliveCountMax/i.test(config)) {
      config = config.replace(/^#?\s*ClientAliveCountMax\s+.*/m, 'ClientAliveCountMax 3')
    } else {
      config += 'ClientAliveCountMax 3\n'
    }

    // Try direct write (root), then sudo
    let wrote = false
    try { writeFileSync(SSHD_CONFIG, config); wrote = true } catch {}
    if (!wrote) {
      const tmp = `/tmp/sshd_config.chono.${process.pid}`
      writeFileSync(tmp, config)
      const cp = spawnSync('sudo', ['cp', tmp, SSHD_CONFIG], { stdio: 'ignore' })
      try { spawnSync('rm', [tmp], { stdio: 'ignore' }) } catch {}
      if (cp.status !== 0) return
    }

    // Reload sshd (works on systemd and sysvinit distros)
    for (const args of [['systemctl', 'reload', 'ssh'], ['systemctl', 'reload', 'sshd'], ['service', 'ssh', 'reload'], ['service', 'sshd', 'reload']]) {
      if (spawnSync(args[0], args.slice(1), { stdio: 'ignore' }).status === 0) break
    }
  } catch {}
}

function applyFlag(flag, model) {
  const idx = process.argv.indexOf(flag)
  if (idx === -1) return false
  const pathArg = process.argv[idx + 1]
  if (!pathArg || pathArg.startsWith('--')) {
    console.error(`chono: ${flag} requires a path argument`)
    process.exit(1)
  }
  const target = resolve(pathArg)
  if (!existsSync(target)) {
    console.error(`chono: path not found: ${target}`)
    process.exit(1)
  }
  process.chdir(target)
  process.argv.splice(idx, 2)
  process.env.CLAUDE_CODE_USE_OPENAI = '1'
  process.env.OPENAI_BASE_URL = `${LITELLM_URL}/v1`
  process.env.OPENAI_API_KEY  = process.env.LITELLM_MASTER_KEY ?? process.env.DEEPSEEK_API_KEY ?? ''
  process.env.OPENAI_MODEL    = model
  return true
}

let needsLitellm = false
for (const [flag, model] of Object.entries(FLAGS)) {
  if (applyFlag(flag, model)) { needsLitellm = true; break }
}

if (needsLitellm) await startLitellm()

ensureSshKeepalive()

const distPath = join(__dirname, '..', 'dist', 'cli.mjs')

if (existsSync(distPath)) {
  await import(pathToFileURL(distPath).href)
} else {
  console.error(`
  chono: dist/cli.mjs not found.

  Build first:
    bun run build
`)
  process.exit(1)
}
