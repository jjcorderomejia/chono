#!/usr/bin/env node

/**
 * Chono — multi-model agentic CLI
 *
 * Usage:
 *   chono --think <path>  # DeepSeek R1 (deepseek-reasoner)
 *   chono --pro <path>    # DeepSeek V4 Pro (deepseek-v4-pro)
 *   chono --flash <path>  # DeepSeek V4 Flash (deepseek-v4-flash)
 */

import { existsSync, mkdirSync, openSync } from 'fs'
import { join, dirname, resolve } from 'path'
import { fileURLToPath, pathToFileURL } from 'url'
import { spawn, execSync } from 'child_process'

const FLAGS = {
  '--think': 'deepseek-reasoner',
  '--pro':   'deepseek-v4-pro',
  '--flash': 'deepseek-v4-flash',
}

const __dirname = dirname(fileURLToPath(import.meta.url))
const PROXY_SCRIPT = join(__dirname, 'chono-proxy.mjs')
const PROXY_PORT   = process.env.CHONO_PROXY_PORT ?? '4799'
const LOG_DIR      = join(process.env.HOME ?? '/tmp', '.chono')

function killOldProxy() {
  try { execSync(`fuser -k ${PROXY_PORT}/tcp 2>/dev/null`, { stdio: 'ignore' }) } catch {}
}

function sessionFile() {
  const now = new Date()
  const pad = n => String(n).padStart(2, '0')
  const ts  = `${now.getFullYear()}${pad(now.getMonth()+1)}${pad(now.getDate())}-${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}`
  return join(LOG_DIR, 'sessions', `${ts}.jsonl`)
}

function startProxy() {
  killOldProxy()
  try { mkdirSync(LOG_DIR, { recursive: true }) } catch {}
  const logFd = openSync(join(LOG_DIR, 'proxy.log'), 'a')
  const child = spawn(process.execPath, [PROXY_SCRIPT], {
    env:    { ...process.env, CHONO_PROXY_PORT: PROXY_PORT, CHONO_SESSION_FILE: sessionFile() },
    stdio:  ['ignore', logFd, logFd],
    detached: false,
  })
  child.unref()
  // Give proxy a moment to bind
  return new Promise(r => setTimeout(r, 300))
}

function applyFlag(flag, model) {
  const idx = process.argv.indexOf(flag)
  if (idx === -1) return false
  const pathArg = process.argv[idx + 1]
  if (!pathArg || pathArg.startsWith('--')) {
    console.error(`chono: ${flag} requires a path argument`)
    process.exit(1)
  }
  const target = resolve(pathArg)
  if (!existsSync(target)) {
    console.error(`chono: path not found: ${target}`)
    process.exit(1)
  }
  process.chdir(target)
  process.argv.splice(idx, 2)
  process.env.CLAUDE_CODE_USE_OPENAI = '1'
  process.env.OPENAI_BASE_URL = `http://127.0.0.1:${PROXY_PORT}/v1`
  process.env.OPENAI_API_KEY  = process.env.DEEPSEEK_API_KEY ?? process.env.OPENAI_API_KEY ?? ''
  process.env.OPENAI_MODEL    = model
  return true
}

let useProxy = false
for (const [flag, model] of Object.entries(FLAGS)) {
  if (applyFlag(flag, model)) { useProxy = true; break }
}

if (useProxy) await startProxy()

const distPath = join(__dirname, '..', 'dist', 'cli.mjs')

if (existsSync(distPath)) {
  await import(pathToFileURL(distPath).href)
} else {
  console.error(`
  chono: dist/cli.mjs not found.

  Build first:
    bun run build
`)
  process.exit(1)
}
